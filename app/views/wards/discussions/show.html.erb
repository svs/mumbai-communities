<div class="max-w-4xl mx-auto space-y-6">
  <!-- Breadcrumb -->
  <div class="text-sm text-gray-500">
    <%= link_to @ward.name, ward_path(@ward), class: "hover:text-blue-600" %> &middot;
    <%= link_to "Discussions", ward_discussions_path(@ward), class: "hover:text-blue-600" %>
  </div>

  <!-- Discussion Header -->
  <div class="border-b border-gray-300 pb-4">
    <div class="flex justify-between items-start">
      <div class="flex-1">
        <div class="flex items-center gap-2 mb-1">
          <% if @discussion.pinned? %>
            <span class="text-yellow-600 text-xs font-medium bg-yellow-50 px-2 py-0.5 rounded">PINNED</span>
          <% end %>
          <% if @discussion.closed? %>
            <span class="text-red-600 text-xs font-medium bg-red-50 px-2 py-0.5 rounded">CLOSED</span>
          <% end %>
          <% if @discussion.archived? %>
            <span class="text-gray-600 text-xs font-medium bg-gray-100 px-2 py-0.5 rounded">ARCHIVED</span>
          <% end %>
        </div>
        <h1 class="text-2xl font-bold text-gray-900"><%= @discussion.title %></h1>
        <div class="text-sm text-gray-500 mt-1">
          by <%= @discussion.user.name || @discussion.user.email %> &middot;
          <%= time_ago_in_words(@discussion.created_at) %> ago
          <% if @discussion.category %>
            &middot; <span class="inline-block px-2 py-0.5 text-xs rounded-full" style="background-color: <%= @discussion.category.color || '#e5e7eb' %>20; color: <%= @discussion.category.color || '#6b7280' %>"><%= @discussion.category.name %></span>
          <% end %>
        </div>
      </div>
      <% if user_signed_in? && (@discussion.user == current_user || current_user.admin?) %>
        <div class="flex gap-2">
          <%= link_to "Edit", edit_ward_discussion_path(@ward, @discussion), class: "text-sm text-gray-600 hover:text-blue-600" %>
          <%= link_to "Delete", ward_discussion_path(@ward, @discussion), data: { turbo_method: :delete, turbo_confirm: "Delete this discussion?" }, class: "text-sm text-red-600 hover:text-red-800" %>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Discussion Body -->
  <div class="prose prose-sm max-w-none text-gray-800 border-b border-gray-200 pb-6">
    <%= simple_format(@discussion.body) %>
  </div>

  <!-- Replies -->
  <div class="space-y-1">
    <h2 class="text-lg font-semibold text-gray-900">
      Replies
      <span class="text-base font-normal text-gray-500">(<%= @discussion.posts_count %>)</span>
    </h2>

    <% if @posts.any? %>
      <% @posts.each do |post| %>
        <%= render partial: "wards/discussions/post", locals: { post: post, ward: @ward, discussion: @discussion, depth: 0 } %>
      <% end %>
    <% else %>
      <p class="text-gray-500 italic py-4">No replies yet.</p>
    <% end %>
  </div>

  <!-- Reply Form -->
  <% if user_signed_in? && @discussion.open? %>
    <div class="border-t border-gray-200 pt-6" id="reply-form">
      <h3 class="text-sm font-semibold text-gray-900 mb-3">Post a Reply</h3>
      <%= form_with(model: @post, url: ward_discussion_posts_path(@ward, @discussion), class: "space-y-3") do |f| %>
        <%= f.text_area :body, rows: 4, placeholder: "Write your reply...", class: "w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-blue-500" %>
        <% if @post.errors[:body].any? %>
          <p class="text-red-600 text-sm"><%= @post.errors[:body].first %></p>
        <% end %>
        <div class="flex justify-end">
          <%= f.submit "Post Reply", class: "bg-blue-600 text-white px-4 py-2 rounded text-sm hover:bg-blue-700 cursor-pointer" %>
        </div>
      <% end %>
    </div>
  <% elsif !user_signed_in? %>
    <div class="border-t border-gray-200 pt-6 text-center text-gray-500 text-sm">
      <%= link_to "Sign in", new_user_session_path, class: "text-blue-600 hover:underline" %> to join the discussion.
    </div>
  <% elsif @discussion.closed? %>
    <div class="border-t border-gray-200 pt-6 text-center text-gray-500 text-sm">
      This discussion is closed.
    </div>
  <% end %>
</div>
