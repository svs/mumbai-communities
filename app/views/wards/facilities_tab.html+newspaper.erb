<turbo-frame id="ward-tab-content">
<%
  mapped_count = @prabhags.select { |p| p.boundary_geojson.present? }.count
  total_facilities = @facility_type_counts.values.sum
  facility_color = lambda { |type|
    case type
    when "hospital" then "#ef4444"
    when "school" then "#3b82f6"
    when "toilet" then "#a855f7"
    when "park", "garden", "open_space" then "#22c55e"
    when "police" then "#1e3a5f"
    when "fire_station" then "#f97316"
    when "library" then "#8b5cf6"
    when "place_of_worship" then "#eab308"
    when "pharmacy" then "#14b8a6"
    when "bank" then "#6366f1"
    when "post_office" then "#f59e0b"
    when "playground" then "#10b981"
    when "bus_station" then "#64748b"
    when "railway_station" then "#475569"
    else "#6b7280"
    end
  }
  facility_icon = lambda { |type|
    case type
    when "hospital" then "fa-hospital"
    when "school" then "fa-school"
    when "toilet" then "fa-restroom"
    when "park", "garden", "open_space" then "fa-tree"
    when "police" then "fa-shield-halved"
    when "fire_station" then "fa-fire-extinguisher"
    when "library" then "fa-book"
    when "place_of_worship" then "fa-place-of-worship"
    when "pharmacy" then "fa-prescription-bottle-medical"
    when "bank" then "fa-building-columns"
    when "post_office" then "fa-envelope"
    when "playground" then "fa-children"
    when "bus_station" then "fa-bus"
    when "railway_station" then "fa-train"
    when "market" then "fa-store"
    when "community_hall" then "fa-people-roof"
    when "swimming_pool" then "fa-person-swimming"
    when "ward_office" then "fa-landmark"
    when "parking" then "fa-square-parking"
    else "fa-location-dot"
    end
  }
%>

  <%= render "wards/tab_nav", current_tab: "Facilities" %>

  <!-- Facility Map Section -->
  <div data-controller="facility-map"
       data-facility-map-url-value="<%= ward_facilities_path(@ward, format: :json) %>"
       data-facility-map-ward-id-value="<%= @ward.ward_code %>">

    <div class="newspaper-section-header">
      Public Facilities
      <span class="text-stone-400 font-normal"><%= total_facilities %> tracked</span>
    </div>

    <!-- Facility type pills as map filters -->
    <% if @facility_type_counts.any? %>
      <div class="flex flex-wrap gap-2 mb-4">
        <% @facility_type_counts.sort_by { |_, count| -count }.each do |type, count| %>
          <label class="inline-flex items-center gap-1.5 text-xs cursor-pointer px-2.5 py-1.5 rounded-full border border-stone-200 hover:bg-stone-50 transition-colors has-[:checked]:bg-stone-800 has-[:checked]:text-white has-[:checked]:border-stone-800">
            <input type="checkbox" checked
                   data-facility-type="<%= type %>"
                   data-action="change->facility-map#toggleType"
                   class="sr-only">
            <i class="fa-solid <%= facility_icon.call(type) %>" style="color: <%= facility_color.call(type) %>;"></i>
            <span><%= type.humanize %></span>
            <span class="opacity-60"><%= count %></span>
          </label>
        <% end %>
      </div>
    <% end %>

    <!-- Map -->
    <div data-controller="leaflet-map"
         data-leaflet-map-data-url-value="<%= ward_path(@ward, format: :json) %>"
         data-leaflet-map-show-labels-value="false"
         data-leaflet-map-show-legend-value="false"
         data-leaflet-map-clickable-value="true"
         data-leaflet-map-zoom-value="15"
         data-leaflet-map-static-value="false">
      <div data-leaflet-map-target="container" class="w-full rounded-lg desaturated-map" style="height: 450px;"></div>
    </div>

    <!-- Facility type cards grid -->
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3 mt-6">
      <% @facility_type_counts.sort_by { |_, count| -count }.each do |type, count| %>
        <%= link_to ward_facilities_path(@ward, type: type),
            class: "group block border border-stone-200 rounded-lg p-3 hover:border-stone-400 hover:shadow-sm transition-all",
            data: { turbo_frame: "_top" } do %>
          <div class="flex items-center gap-2 mb-1">
            <i class="fa-solid <%= facility_icon.call(type) %> text-sm" style="color: <%= facility_color.call(type) %>;"></i>
            <span class="text-2xl font-bold text-stone-800"><%= count %></span>
          </div>
          <div class="text-xs text-stone-500 group-hover:text-stone-700"><%= type.humanize.pluralize %></div>
        <% end %>
      <% end %>
    </div>
  </div>

  <!-- Data Coverage -->
  <% if total_facilities > 0 %>
    <div class="mt-10 mb-10">
      <div class="newspaper-section-header">
        Data Coverage
        <span class="text-stone-400 font-normal">OSM vs BMC official records</span>
      </div>
      <p class="text-sm text-stone-500 mb-4">
        We cross-reference OpenStreetMap data with BMC's official records. Gaps mean either the facility isn't mapped online or BMC doesn't have it in their systems.
      </p>
      <turbo-frame id="facilities-scorecard" src="<%= scorecard_ward_facilities_path(@ward) %>" loading="lazy">
        <div class="text-sm text-stone-400 italic p-4">Loading scorecard...</div>
      </turbo-frame>
    </div>
  <% end %>

  <!-- Prabhags -->
  <div class="mb-10">
    <div class="newspaper-section-header">
      Prabhags
      <span class="text-stone-400 font-normal"><%= mapped_count %>/<%= @prabhags.count %> mapped</span>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <% @prabhags.each do |prabhag| %>
        <% boundary = prabhag.approved_boundary %>
        <%
          if boundary
            case boundary.source_type
            when 'official_import'
              border_color = 'border-green-500'
              status_text = boundary.status == 'canonical' ? 'Official' : 'Approved'
              status_class = 'bg-green-50 text-green-700'
            when 'kml_import'
              border_color = 'border-orange-400'
              status_text = 'Legacy'
              status_class = 'bg-orange-50 text-orange-700'
            when 'user_submission'
              border_color = 'border-purple-400'
              status_text = 'Community'
              status_class = 'bg-purple-50 text-purple-700'
            else
              border_color = 'border-stone-300'
              status_text = boundary.source_type.humanize
              status_class = 'bg-stone-50 text-stone-600'
            end
          else
            border_color = 'border-red-400'
            status_text = 'Needs mapping'
            status_class = 'bg-red-50 text-red-700'
          end
        %>
        <%= link_to prabhag_path(prabhag), class: "prabhag-card block border-t-4 #{border_color} bg-white rounded-lg border border-stone-200 p-4 hover:no-underline hover:shadow-sm transition-all", data: { turbo_frame: "_top" } do %>
          <div class="text-lg font-semibold text-stone-800 mb-1">
            Prabhag <%= prabhag.number %>
          </div>
          <span class="inline-block text-xs font-medium px-2 py-1 rounded-full <%= status_class %>">
            <%= status_text %>
          </span>
        <% end %>
      <% end %>
    </div>
  </div>

  <!-- How to help -->
  <div class="mb-10">
    <div class="newspaper-section-header">Help Improve This Data</div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="border border-stone-200 rounded-lg p-4">
        <div class="text-sm font-semibold text-stone-800 mb-1">
          <i class="fa-solid fa-camera text-blue-500 mr-1"></i> Audit a Facility
        </div>
        <p class="text-xs text-stone-500">
          Visit a school, hospital, or garden near you. Take photos. Report what you find.
        </p>
      </div>
      <div class="border border-stone-200 rounded-lg p-4">
        <div class="text-sm font-semibold text-stone-800 mb-1">
          <i class="fa-solid fa-map text-orange-500 mr-1"></i> Add Missing Facilities
        </div>
        <p class="text-xs text-stone-500">
          Know a school or hospital that's not on our map? Help us add it.
        </p>
      </div>
    </div>
  </div>
</turbo-frame>
