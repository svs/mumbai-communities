<div class="max-w-6xl mx-auto py-8 px-4">

  <!-- Masthead -->
  <div class="flex items-baseline justify-between border-b-2 border-stone-900 pb-2 mb-6">
    <h1 class="newspaper-masthead text-3xl md:text-4xl text-stone-900">
      Mumbai Communities
    </h1>
    <p class="text-xs text-stone-400">
      <%= Date.current.strftime("%A, %B %-d, %Y") %>
      &ensp;·&ensp;
      <%= @wards.count %> Wards
      &ensp;·&ensp;
      <%= @total_tweet_count %> dispatches
    </p>
  </div>

  <!-- Main Grid -->
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">

    <!-- Feed (8 cols) -->
    <div class="lg:col-span-8">
      <div class="newspaper-section-header">From the Community</div>

      <% if @tweets.any? %>
        <% @tweets.each do |tweet| %>
          <div class="newspaper-dispatch">
            <div class="flex items-center gap-3 mb-2">
              <%= link_to "Ward #{tweet.ward.ward_code}", ward_path(tweet.ward), class: "newspaper-dateline hover:underline" %>
              <span class="text-xs text-stone-400">
                <%= time_ago_in_words(tweet.tweeted_at) %> ago
              </span>
            </div>
            <%= render tweet %>
          </div>
        <% end %>

        <div class="mt-6">
          <%= paginate @tweets %>
        </div>
      <% else %>
        <p class="text-sm text-stone-400 italic">No community dispatches yet.</p>
      <% end %>
    </div>

    <!-- Sidebar (4 cols) -->
    <div class="lg:col-span-4">
      <div class="lg:sticky lg:top-4">

        <!-- Topics -->
        <% if @category_counts.present? %>
          <div class="mb-6">
            <div class="newspaper-section-header">Topics</div>
            <div class="space-y-1">
              <%= link_to "All", wards_path,
                  class: "block text-sm px-2 py-1 rounded #{'bg-stone-800 text-white' if params[:category].blank?} #{'text-stone-600 hover:bg-stone-100' if params[:category].present?}" %>
              <% @category_counts.sort_by { |_, v| -v }.each do |category, count| %>
                <%= link_to wards_path(category: category),
                    class: "flex justify-between items-center text-sm px-2 py-1 rounded #{'bg-stone-800 text-white' if params[:category] == category} #{'text-stone-600 hover:bg-stone-100' if params[:category] != category}" do %>
                  <span><%= category.humanize %></span>
                  <span class="text-xs <%= params[:category] == category ? 'text-stone-300' : 'text-stone-400' %>"><%= count %></span>
                <% end %>
              <% end %>
            </div>
          </div>
        <% end %>

        <!-- Location Search -->
        <div class="mb-6" data-controller="location-search" data-action="click@window->location-search#closeResults">
          <div class="newspaper-section-header">Find Your Ward</div>
          <div class="relative">
            <input type="text"
                   data-location-search-target="input"
                   data-action="input->location-search#search keydown->location-search#keydown"
                   placeholder="Search for a place in Mumbai..."
                   class="w-full text-sm border border-stone-300 rounded px-3 py-2 focus:outline-none focus:ring-1 focus:ring-stone-400">
            <div data-location-search-target="results"
                 class="hidden absolute z-10 w-full bg-white border border-stone-200 rounded shadow-lg mt-1 max-h-48 overflow-y-auto">
            </div>
          </div>
        </div>

        <!-- Ward Index -->
        <div class="mb-6">
          <div class="newspaper-section-header">Wards</div>
          <div class="grid grid-cols-2 gap-x-2">
            <% @wards.each do |ward| %>
              <% count = @ward_tweet_counts[ward.id] || 0 %>
              <% next if count == 0 %>
              <%= link_to ward_path(ward),
                  class: "newspaper-sidebar-link flex justify-between items-center py-1 px-2 rounded" do %>
                <span class="text-xs font-medium text-stone-700 truncate"><%= ward.ward_code %></span>
                <span class="text-xs text-stone-400"><%= count %></span>
              <% end %>
            <% end %>
          </div>
        </div>

        <!-- Sign in prompt (anonymous users) -->
        <% unless user_signed_in? %>
          <div class="mb-6">
            <div class="newspaper-section-header">Join</div>
            <p class="text-sm text-stone-600 mb-3">
              Sign in to contribute to your ward community.
            </p>
            <%= link_to "Sign in with Google", user_google_oauth2_omniauth_authorize_path,
                        method: :post,
                        class: "block text-center text-sm font-medium text-stone-700 border border-stone-300 rounded px-4 py-2 hover:bg-stone-50 transition-colors" %>
          </div>
        <% end %>

      </div>
    </div>
  </div>

  <!-- Footer -->
  <div class="newspaper-rule mb-6 mt-12"></div>
  <div class="flex justify-center gap-8 text-sm text-stone-500">
    <%= link_to "Boundary Mapping", prabhags_path,
                class: "hover:text-stone-800 underline" %>
    <a href="https://portal.mcgm.gov.in" target="_blank"
       class="hover:text-stone-800 underline">MCGM Portal</a>
  </div>
</div>
