<turbo-frame id="ward-tab-content">
  <%= render "wards/tab_nav", current_tab: "Officials" %>

  <% if @positions.any? %>
    <%
      # Split into leadership (senior) and staff
      all_senior = @positions.select { |p| p.level == "senior" }
      # Deduplicate by person (same person as AC and DO — show once)
      seen_person_ids = Set.new
      leadership = all_senior.select do |pos|
        if pos.person_id.present? && seen_person_ids.include?(pos.person_id)
          false
        else
          seen_person_ids << pos.person_id if pos.person_id.present?
          true
        end
      end
      # Exclude ALL senior positions from staff (including deduped ones)
      senior_ids = all_senior.map(&:id).to_set
      staff = @positions.reject { |p| senior_ids.include?(p.id) }
      sections = staff.group_by(&:section).sort_by { |name, _| name || "" }
    %>

    <!-- Ward Leadership -->
    <% if leadership.any? %>
      <div class="newspaper-section-header">Ward Leadership</div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-10">
        <% leadership.each do |pos| %>
          <div class="border border-stone-200 rounded-lg p-5">
            <% if pos.person %>
              <%= link_to pos.person.name, position_path(pos), class: "font-semibold text-stone-900 text-base hover:text-blue-600 transition-colors", data: { turbo_frame: "_top" } %>
            <% else %>
              <div class="font-semibold text-stone-400 text-base italic">Vacant</div>
            <% end %>
            <div class="text-sm text-stone-500 mt-0.5"><%= pos.designation %></div>
            <div class="flex items-center gap-3 mt-3">
              <% phone = pos.person&.phone || pos.phone %>
              <% if phone.present? %>
                <a href="tel:<%= phone %>" class="inline-flex items-center gap-1 text-xs text-stone-600 hover:text-stone-800">
                  <i class="fa-solid fa-phone"></i> <%= phone %>
                </a>
              <% end %>
              <% if pos.email.present? %>
                <a href="mailto:<%= pos.email %>" class="inline-flex items-center gap-1 text-xs text-blue-600 hover:text-blue-800">
                  <i class="fa-solid fa-envelope"></i> email
                </a>
              <% end %>
              <% if pos.person&.linkedin_url.present? %>
                <a href="<%= pos.person.linkedin_url %>" target="_blank" class="inline-flex items-center gap-1 text-xs text-blue-600 hover:text-blue-800">
                  <i class="fa-brands fa-linkedin"></i>
                </a>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

    <!-- Staff by Section -->
    <% if sections.any? %>
      <div class="newspaper-section-header">Department Staff</div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-6">
        <% sections.each do |section_name, positions| %>
          <div class="border border-stone-200 rounded-lg p-4 max-h-64 overflow-y-auto">
            <h4 class="text-xs font-bold uppercase tracking-wider text-stone-400 mb-3 sticky top-0 bg-white"><%= section_name || "General" %></h4>
            <div class="space-y-3">
              <% positions.each do |pos| %>
                <div class="flex items-start justify-between gap-2">
                  <div class="min-w-0">
                    <% if pos.person %>
                      <div class="text-sm font-medium text-stone-800"><%= pos.person.name %></div>
                      <div class="text-xs text-stone-500"><%= pos.designation %></div>
                    <% else %>
                      <div class="text-sm text-stone-600"><%= pos.designation %></div>
                    <% end %>
                  </div>
                  <div class="flex items-center gap-2 shrink-0">
                    <% phone = pos.person&.phone || pos.phone %>
                    <% if phone.present? %>
                      <a href="tel:<%= phone %>" class="text-stone-400 hover:text-stone-600" title="<%= phone %>">
                        <i class="fa-solid fa-phone text-xs"></i>
                      </a>
                    <% end %>
                    <% if pos.email.present? %>
                      <a href="mailto:<%= pos.email %>" class="text-blue-600 hover:text-blue-800" title="<%= pos.email %>">
                        <i class="fa-solid fa-envelope text-xs"></i>
                      </a>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

    <div class="text-xs text-stone-400 mb-10">
      Source: BMC Civic Diary 2025 &middot;
      <a href="https://portal.mcgm.gov.in" target="_blank" class="text-blue-600 hover:underline">MCGM Portal</a>
    </div>

  <% else %>
    <p class="text-sm text-stone-400 italic mb-10">No officer data available yet.</p>
  <% end %>

  <!-- How to reach them -->
  <div class="mb-10">
    <div class="newspaper-section-header">How to Reach Your Ward Office</div>
    <div class="text-sm text-stone-600 space-y-3">
      <p>
        Every ward has a Ward Office headed by an Assistant Commissioner. You can email officials directly using the contacts above,
        or visit the ward office in person.
      </p>
      <p>
        For complaints, use the BMC complaint portal or tweet
        <% if @ward.twitter_handle.present? %>
          <a href="https://twitter.com/<%= @ward.twitter_handle.delete('@') %>" target="_blank" class="text-blue-600 hover:underline font-medium"><%= @ward.twitter_handle %></a>
        <% else %>
          your ward's official Twitter handle
        <% end %>
        for faster response.
      </p>
    </div>
  </div>
</turbo-frame>
