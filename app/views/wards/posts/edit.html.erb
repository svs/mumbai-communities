<div class="max-w-2xl mx-auto space-y-6">
  <div class="text-sm text-gray-500">
    <%= link_to @ward.name, ward_path(@ward), class: "hover:text-blue-600" %> &middot;
    <%= link_to "Discussions", ward_discussions_path(@ward), class: "hover:text-blue-600" %> &middot;
    <%= link_to @discussion.title, ward_discussion_path(@ward, @discussion), class: "hover:text-blue-600" %> &middot; Edit Reply
  </div>

  <h1 class="text-xl font-bold text-gray-900">Edit Reply</h1>

  <%= form_with(model: @post, url: ward_discussion_post_path(@ward, @discussion, @post), class: "space-y-4") do |f| %>
    <% if @post.errors.any? %>
      <div class="bg-red-50 border border-red-200 text-red-700 p-3 rounded text-sm">
        <% @post.errors.full_messages.each do |msg| %>
          <p><%= msg %></p>
        <% end %>
      </div>
    <% end %>

    <div>
      <%= f.text_area :body, rows: 6, class: "w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-blue-500" %>
    </div>

    <div class="flex justify-between items-center">
      <%= link_to "Cancel", ward_discussion_path(@ward, @discussion), class: "text-sm text-gray-500 hover:text-gray-700" %>
      <%= f.submit "Update Reply", class: "bg-blue-600 text-white px-4 py-2 rounded text-sm hover:bg-blue-700 cursor-pointer" %>
    </div>
  <% end %>
</div>
