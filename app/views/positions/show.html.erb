<div class="max-w-4xl mx-auto py-8 px-4">
  <%
    person = @position.person
    phone = person&.phone || @position.phone
  %>

  <!-- Breadcrumb -->
  <div class="text-sm text-stone-400 mb-6">
    <% if @ward %>
      <%= link_to @ward.name, ward_path(@ward), class: "hover:text-stone-600" %>
      <span class="mx-1">/</span>
      <%= link_to "Officials", officials_ward_path(@ward), class: "hover:text-stone-600" %>
      <span class="mx-1">/</span>
    <% end %>
    <span class="text-stone-600"><%= person&.name || @position.designation %></span>
  </div>

  <!-- Officer Header -->
  <div class="flex items-start gap-6 mb-8 pb-8 border-b border-stone-200">
    <% if person&.avatar_url.present? %>
      <img src="<%= person.avatar_url %>" alt="<%= person.name %>" class="w-20 h-20 rounded-full object-cover shrink-0 bg-stone-100">
    <% else %>
      <div class="w-20 h-20 rounded-full bg-stone-100 flex items-center justify-center shrink-0">
        <i class="fa-solid fa-user text-3xl text-stone-300"></i>
      </div>
    <% end %>
    <div class="flex-1">
      <h1 class="text-2xl font-bold text-stone-900">
        <%= person&.name || "Vacant Position" %>
      </h1>
      <p class="text-stone-600 mt-1"><%= @position.designation %></p>
      <% if @position.section.present? || @ward %>
        <p class="text-sm text-stone-500">
          <%= [@position.section, @ward&.name].compact.join(" · ") %>
        </p>
      <% end %>

      <!-- Contact -->
      <div class="flex flex-wrap items-center gap-4 mt-4">
        <% if phone.present? %>
          <a href="tel:<%= phone %>" class="inline-flex items-center gap-1.5 text-sm text-stone-700 hover:text-stone-900">
            <i class="fa-solid fa-phone text-stone-400"></i> <%= phone %>
          </a>
        <% end %>
        <% if @position.email.present? %>
          <a href="mailto:<%= @position.email %>" class="inline-flex items-center gap-1.5 text-sm text-blue-600 hover:text-blue-800">
            <i class="fa-solid fa-envelope"></i> <%= @position.email %>
          </a>
        <% end %>
        <% if person&.linkedin_url.present? %>
          <a href="<%= person.linkedin_url %>" target="_blank" class="inline-flex items-center gap-1.5 text-sm text-blue-600 hover:text-blue-800">
            <i class="fa-brands fa-linkedin"></i> LinkedIn
          </a>
        <% end %>
        <% if person&.twitter_handle.present? %>
          <a href="https://twitter.com/<%= person.twitter_handle.delete('@') %>" target="_blank" class="inline-flex items-center gap-1.5 text-sm text-blue-600 hover:text-blue-800">
            <i class="fa-brands fa-x-twitter"></i> <%= person.twitter_handle %>
          </a>
        <% end %>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Main Content -->
    <div class="lg:col-span-2 space-y-8">

      <!-- Bio -->
      <% if person&.bio.present? %>
        <div>
          <h2 class="text-sm font-bold uppercase tracking-wider text-stone-400 mb-3">About</h2>
          <p class="text-stone-700 leading-relaxed"><%= person.bio %></p>
        </div>
      <% end %>

      <!-- Other Positions -->
      <% if person && @other_positions.any? %>
        <div>
          <h2 class="text-sm font-bold uppercase tracking-wider text-stone-400 mb-3">Also Serves As</h2>
          <div class="space-y-2">
            <% @other_positions.each do |pos| %>
              <div class="text-sm">
                <span class="font-medium text-stone-800"><%= pos.designation %></span>
                <span class="text-stone-500">— <%= pos.section || pos.organisation.name %></span>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

      <!-- News Coverage -->
      <% news_articles = person&.profile_data&.dig("news") || [] %>
      <div>
        <h2 class="text-sm font-bold uppercase tracking-wider text-stone-400 mb-3">In the News</h2>
        <% if news_articles.any? %>
          <div class="space-y-4">
            <% news_articles.each do |article| %>
              <a href="<%= article['url'] %>" target="_blank" class="block border border-stone-200 rounded-lg p-4 hover:border-stone-400 hover:shadow-sm transition-all group">
                <div class="font-medium text-stone-800 group-hover:text-blue-600"><%= article['title'] %></div>
                <% if article['excerpt'].present? %>
                  <p class="text-sm text-stone-500 mt-1 line-clamp-2"><%= article['excerpt'] %></p>
                <% end %>
                <div class="text-xs text-stone-400 mt-2">
                  <%= article['source'] %>
                  <% if article['date'].present? %>
                    &middot; <%= article['date'] %>
                  <% end %>
                </div>
              </a>
            <% end %>
          </div>
        <% else %>
          <p class="text-sm text-stone-400 italic">No news coverage found yet.</p>
        <% end %>
      </div>

      <!-- Ward Tweets Mentioning This Person -->
      <% if @ward && person %>
        <%
          last_name = person.name.split.last
          related_tweets = @ward.tweets.original.where("body LIKE ?", "%#{last_name}%").limit(5)
        %>
        <% if related_tweets.any? %>
          <div>
            <h2 class="text-sm font-bold uppercase tracking-wider text-stone-400 mb-3">Community Mentions</h2>
            <div class="space-y-3">
              <% related_tweets.each do |tweet| %>
                <%= link_to ward_tweet_path(@ward, tweet), class: "block border-l-2 border-stone-200 pl-4 py-2 hover:border-stone-400 hover:bg-stone-50 transition-colors" do %>
                  <p class="text-sm text-stone-700 line-clamp-2"><%= truncate(tweet.body, length: 200) %></p>
                  <div class="text-xs text-stone-400 mt-1">@<%= tweet.author_username %> &middot; <%= time_ago_in_words(tweet.tweeted_at) %> ago</div>
                <% end %>
              <% end %>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>

    <!-- Sidebar -->
    <div class="space-y-6">
      <div class="border border-stone-200 rounded-lg p-4">
        <h3 class="text-sm font-bold uppercase tracking-wider text-stone-400 mb-3">Details</h3>
        <div class="space-y-2 text-sm">
          <% if @ward %>
            <div class="flex justify-between">
              <span class="text-stone-500">Ward</span>
              <span class="font-medium text-stone-800"><%= @ward.name %></span>
            </div>
          <% end %>
          <% if @position.section.present? %>
            <div class="flex justify-between">
              <span class="text-stone-500">Section</span>
              <span class="font-medium text-stone-800"><%= @position.section %></span>
            </div>
          <% end %>
          <div class="flex justify-between">
            <span class="text-stone-500">Designation</span>
            <span class="font-medium text-stone-800"><%= @position.designation %></span>
          </div>
          <% if @position.level.present? %>
            <div class="flex justify-between">
              <span class="text-stone-500">Level</span>
              <span class="font-medium text-stone-800"><%= @position.level.capitalize %></span>
            </div>
          <% end %>
          <% if @position.started_on.present? %>
            <div class="flex justify-between">
              <span class="text-stone-500">Since</span>
              <span class="font-medium text-stone-800"><%= @position.started_on.strftime("%b %Y") %></span>
            </div>
          <% end %>
        </div>
      </div>

      <% if @ward %>
        <div class="border border-stone-200 rounded-lg p-4">
          <h3 class="text-sm font-bold uppercase tracking-wider text-stone-400 mb-3">Ward</h3>
          <%= link_to ward_path(@ward), class: "block hover:bg-stone-50 rounded p-2 -m-2 transition-colors" do %>
            <div class="font-medium text-stone-800"><%= @ward.name %></div>
            <div class="text-xs text-stone-500">
              <%= @ward.prabhags.count %> prabhags
              &middot; <%= @ward.facilities.count %> facilities
            </div>
          <% end %>
        </div>
      <% end %>

      <!-- Position History -->
      <% if person && person.positions.count > 1 %>
        <div class="border border-stone-200 rounded-lg p-4">
          <h3 class="text-sm font-bold uppercase tracking-wider text-stone-400 mb-3">Career History</h3>
          <div class="space-y-2">
            <% person.positions.order(started_on: :desc).each do |pos| %>
              <div class="text-sm">
                <div class="font-medium text-stone-800"><%= pos.designation %></div>
                <div class="text-xs text-stone-500">
                  <%= pos.organisation.name %>
                  <% if pos.started_on %>
                    &middot; <%= pos.started_on.strftime("%b %Y") %><%= pos.ended_on ? " – #{pos.ended_on.strftime('%b %Y')}" : " – present" %>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
