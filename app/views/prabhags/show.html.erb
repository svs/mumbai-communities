<% badge = @prabhag.mapping_status_badge %>

<div class="w-full">
  <%# Breadcrumb %>
  <nav class="flex items-center space-x-2 text-sm mb-3">
    <%= link_to "Home", root_path, class: "text-blue-600 hover:text-blue-800" %>
    <span class="text-gray-400">/</span>
    <%= link_to "Wards", wards_path, class: "text-blue-600 hover:text-blue-800" %>
    <% if @ward %>
      <span class="text-gray-400">/</span>
      <%= link_to @ward.name, ward_path(@ward), class: "text-blue-600 hover:text-blue-800" %>
    <% end %>
    <span class="text-gray-400">/</span>
    <span class="text-gray-700">Prabhag <%= @prabhag.number %></span>
  </nav>

  <%# Header %>
  <div class="flex items-center justify-between mb-4">
    <div>
      <div class="flex items-center gap-3">
        <h1 class="text-3xl font-bold text-stone-900">Prabhag <%= @prabhag.number %></h1>
        <span class="px-2.5 py-1 text-xs font-medium rounded-full <%= badge[:bg] %> <%= badge[:text] %>"><%= badge[:label] %></span>
      </div>
      <% if @ward %>
        <p class="text-stone-500 mt-0.5"><%= @ward.name %></p>
      <% end %>
    </div>
    <% if user_signed_in? && current_user.admin? %>
      <%= link_to "Admin", admin_prabhag_path(@prabhag),
                  class: "px-3 py-1.5 bg-purple-600 hover:bg-purple-700 text-white text-sm font-medium rounded" %>
    <% end %>
  </div>

  <%# Progress bar — always visible %>
  <div class="flex items-center gap-2 text-xs mb-6">
    <% steps = [
      { label: "Map boundary", done: [:pending, :mapped, :enriched, :active].include?(@stage), current: @stage == :unmapped, pending: @stage == :pending },
      { label: "Discover facilities", done: [:enriched, :active].include?(@stage), current: @stage == :mapped },
      { label: "Organize & improve", done: @stage == :active, current: @stage == :enriched }
    ] %>
    <% steps.each_with_index do |step, i| %>
      <% if step[:done] %>
        <span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-green-600 text-white"><i class="fas fa-check text-[10px]"></i></span>
        <span class="text-green-700"><%= step[:label] %></span>
      <% elsif step[:pending] %>
        <span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-yellow-500 text-white font-bold"><%= i + 1 %></span>
        <span class="font-semibold text-yellow-700"><%= step[:label] %> (under review)</span>
      <% elsif step[:current] %>
        <span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-blue-600 text-white font-bold"><%= i + 1 %></span>
        <span class="font-semibold text-stone-700"><%= step[:label] %></span>
      <% else %>
        <span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-stone-200 text-stone-400 font-bold"><%= i + 1 %></span>
        <span class="text-stone-400"><%= step[:label] %></span>
      <% end %>
      <% unless i == steps.length - 1 %>
        <span class="text-stone-300">→</span>
      <% end %>
    <% end %>
  </div>

  <%# ===== UNMAPPED ===== %>
  <% if @stage == :unmapped %>

    <%# Check for rejected history %>
    <% rejected = @prabhag.boundaries.where(status: 'rejected').order(created_at: :desc).first %>
    <% if rejected %>
      <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-6 text-sm">
        <p class="text-red-800 font-medium">Previous submission was rejected</p>
        <% if rejected.rejection_reason.present? %>
          <p class="text-red-700 mt-1"><%= rejected.rejection_reason %></p>
        <% end %>
        <p class="text-red-600 mt-1 text-xs">
          This prabhag is available for remapping.
        </p>
      </div>
    <% end %>

    <div class="bg-stone-50 border border-stone-200 rounded-lg p-8 mb-8">
      <h2 class="text-2xl font-bold text-stone-800 mb-3">This neighborhood needs to be put on the map</h2>
      <p class="text-stone-600 mb-4 max-w-2xl">
        Prabhag <%= @prabhag.number %> is home to tens of thousands of people, schools, hospitals,
        and parks — but none of it can be tracked until someone traces its boundary from the official map below.
      </p>
      <p class="text-sm text-stone-500 mb-6">
        <strong>Once mapped, we unlock:</strong>
        every school, hospital, park, and public toilet inside this boundary — pulled automatically from OpenStreetMap.
        Residents can then discuss, audit, and organize around real data.
      </p>

      <% if user_signed_in? %>
        <% if @prabhag.can_be_assigned_to?(current_user) %>
          <%= link_to assign_prabhag_path(@prabhag),
                      class: "inline-flex items-center px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-lg",
                      data: { turbo_method: :post, confirm: "Assign this prabhag to yourself?" } do %>
            <i class="fas fa-pencil-alt mr-2"></i> Volunteer to Map
          <% end %>
        <% elsif @prabhag.assigned_to == current_user && @prabhag.status == 'assigned' %>
          <%= link_to trace_prabhag_path(@prabhag),
                      class: "inline-flex items-center px-6 py-3 bg-green-600 hover:bg-green-700 text-white font-semibold rounded-lg" do %>
            <i class="fas fa-map-marked-alt mr-2"></i> Continue Mapping
          <% end %>
        <% elsif @prabhag.assigned_to.present? %>
          <p class="text-stone-500 text-sm">
            <i class="fas fa-user-clock mr-1"></i>
            Being mapped by <strong><%= @prabhag.assigned_to.name || @prabhag.assigned_to.email.split('@').first %></strong>
          </p>
        <% end %>
      <% else %>
        <%= link_to new_user_session_path, class: "inline-flex items-center px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-lg" do %>
          <i class="fas fa-sign-in-alt mr-2"></i> Sign in to help map
        <% end %>
      <% end %>
    </div>

    <%# PDF is THE content for unmapped prabhags %>
    <h3 class="text-sm font-semibold text-stone-700 uppercase tracking-wide mb-3">Official Reference Map</h3>
    <%= render partial: "prabhags/pdf_embed", locals: { prabhag: @prabhag } %>

  <%# ===== PENDING ===== %>
  <% elsif @stage == :pending %>

    <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-6 mb-6">
      <h2 class="text-xl font-bold text-yellow-800 mb-2">Boundary submitted — waiting for review</h2>
      <p class="text-yellow-700 text-sm">
        <% if @boundary&.submitted_by %>
          <strong><%= @boundary.submitted_by.name || @boundary.submitted_by.email.split('@').first %></strong> traced this boundary.
        <% end %>
        Once approved, facility data from OpenStreetMap will be loaded automatically.
      </p>
    </div>

    <%# Inline admin review %>
    <% if user_signed_in? && current_user.admin? && @boundary %>
      <div class="bg-purple-50 border border-purple-200 rounded-lg p-4 mb-6">
        <h3 class="text-sm font-semibold text-purple-800 mb-3">Admin Review</h3>
        <div class="flex items-center gap-3">
          <%= button_to "Approve",
                        approve_admin_prabhag_boundary_path(@prabhag, @boundary),
                        method: :post,
                        params: { return_to: prabhag_path(@prabhag) },
                        class: "px-4 py-2 bg-green-600 hover:bg-green-700 text-white text-sm font-medium rounded",
                        form: { data: { turbo_confirm: "Approve this boundary?" } } %>
          <%= form_with url: reject_admin_prabhag_boundary_path(@prabhag, @boundary),
                        method: :post, class: "flex items-center gap-2", data: { turbo_confirm: "Reject this boundary?" } do |f| %>
            <%= f.hidden_field :return_to, value: prabhag_path(@prabhag) %>
            <%= f.text_field :rejection_reason,
                             placeholder: "Reason (optional)",
                             class: "px-3 py-2 border border-stone-300 rounded text-sm w-48" %>
            <%= f.submit "Reject", class: "px-4 py-2 bg-red-600 hover:bg-red-700 text-white text-sm font-medium rounded cursor-pointer" %>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# Map showing submitted boundary %>
    <% if @boundary&.geojson.present? %>
      <div class="w-full bg-white rounded-lg border border-stone-200 overflow-hidden mb-6"
           style="height: 450px;"
           data-controller="leaflet-map"
           data-leaflet-map-data-url-value="<%= prabhag_path(@prabhag, format: :json) %>"
           data-leaflet-map-show-labels-value="true"
           data-leaflet-map-show-legend-value="false"
           data-leaflet-map-clickable-value="false"
           data-leaflet-map-zoom-value="15"
           data-leaflet-map-static-value="false">
        <div data-leaflet-map-target="container" class="w-full h-full desaturated-map"></div>
      </div>
    <% end %>

    <%# PDF for comparison — open by default for admins %>
    <details class="mb-6" <%= "open" if user_signed_in? && current_user.admin? %>>
      <summary class="text-sm font-semibold text-stone-600 cursor-pointer hover:text-stone-800">
        <i class="fas fa-file-pdf mr-1 text-red-400"></i> Official Reference Map (compare with submission)
      </summary>
      <div class="mt-3">
        <%= render partial: "prabhags/pdf_embed", locals: { prabhag: @prabhag } %>
      </div>
    </details>

  <%# ===== MAPPED / ENRICHED / ACTIVE ===== %>
  <% else %>

    <%# Legacy KML warning %>
    <% if @prabhag.computed_mapping_status == :legacy_needs_remapping %>
      <div class="bg-orange-50 border border-orange-200 rounded-lg p-4 mb-6 text-sm">
        <p class="text-orange-800">
          <i class="fas fa-exclamation-triangle mr-1"></i>
          <strong>This boundary is from a 2017 KML import</strong> and may not match the 2025 official map.
        </p>
        <% if user_signed_in? && @prabhag.can_be_assigned_to?(current_user) %>
          <%= link_to "Remap from 2025 PDF", assign_prabhag_path(@prabhag),
                      class: "inline-block mt-2 text-sm font-medium text-orange-700 hover:text-orange-900 underline",
                      data: { turbo_method: :post, confirm: "Assign this prabhag to yourself for remapping?" } %>
        <% elsif !user_signed_in? %>
          <p class="mt-1 text-orange-600"><%= link_to "Sign in", new_user_session_path, class: "underline" %> to help remap.</p>
        <% end %>
      </div>
    <% end %>

    <%# Map with boundary + facility markers %>
    <% if @boundary&.geojson.present? %>
      <div class="w-full bg-white rounded-lg border border-stone-200 overflow-hidden mb-6"
           style="height: 500px;"
           data-controller="leaflet-map"
           data-leaflet-map-data-url-value="<%= prabhag_path(@prabhag, format: :json) %>"
           data-leaflet-map-show-labels-value="true"
           data-leaflet-map-show-legend-value="false"
           data-leaflet-map-clickable-value="false"
           data-leaflet-map-zoom-value="15"
           data-leaflet-map-static-value="false">
        <div data-leaflet-map-target="container" class="w-full h-full desaturated-map"></div>
      </div>
    <% end %>

    <%# What's here — POIs from OSM %>
    <% if @poi_groups.any? %>
      <div class="mb-8">
        <h2 class="text-lg font-semibold text-stone-900 pb-2 border-b border-stone-200 mb-4">
          What's here
          <span class="text-sm font-normal text-stone-400 ml-2"><%= @pois.size %> places</span>
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          <% @poi_groups.sort_by { |_, pois| -pois.size }.each do |type, pois| %>
            <div>
              <h3 class="text-sm font-semibold text-stone-700 mb-2 capitalize"><%= type.to_s.humanize.pluralize %> (<%= pois.size %>)</h3>
              <ul class="space-y-1">
                <% pois.first(5).each do |poi| %>
                  <li class="text-sm text-stone-600"><%= poi[:name].presence || "Unnamed #{type.to_s.humanize.downcase}" %></li>
                <% end %>
                <% if pois.size > 5 %>
                  <li class="text-xs text-stone-400">+ <%= pois.size - 5 %> more</li>
                <% end %>
              </ul>
            </div>
          <% end %>
        </div>
      </div>
    <% elsif @prabhag_facilities.present? %>
      <%# Fallback: facilities within boundary from stored data %>
      <%
        type_labels = {
          "place_of_worship" => "Places of worship",
          "bus_station" => "Bus stations",
          "fire_station" => "Fire stations",
          "railway_station" => "Railway stations",
          "post_office" => "Post offices"
        }
        type_colors = {
          "hospital" => "#ef4444", "school" => "#3b82f6", "college" => "#3b82f6",
          "bank" => "#6366f1", "police" => "#1e3a5f", "park" => "#22c55e",
          "pharmacy" => "#14b8a6", "place_of_worship" => "#eab308",
          "post_office" => "#f59e0b", "fire_station" => "#f97316",
          "library" => "#8b5cf6", "playground" => "#10b981",
          "bus_station" => "#64748b", "railway_station" => "#475569",
          "garden" => "#22c55e"
        }
        facility_groups = @prabhag_facilities.group_by(&:facility_type)
      %>
      <div class="mb-8">
        <h2 class="text-lg font-semibold text-stone-900 pb-2 border-b border-stone-200 mb-4">
          What's here
          <span class="text-sm font-normal text-stone-400 ml-2"><%= @prabhag_facilities.size %> places</span>
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-5">
          <% facility_groups.sort_by { |_, fs| -fs.size }.each do |type, facilities| %>
            <%
              label = type_labels[type] || type.humanize.pluralize
              color = type_colors[type] || "#6b7280"
              named = facilities.select { |f| f.name.present? }
              unnamed = facilities.reject { |f| f.name.present? }
              by_name = named.group_by(&:name).sort_by { |name, _| name.downcase }
            %>
            <div>
              <h3 class="text-xs font-semibold uppercase tracking-wide mb-2 flex items-center gap-1.5">
                <span class="inline-block w-2.5 h-2.5 rounded-full flex-shrink-0" style="background-color: <%= color %>;"></span>
                <span class="text-stone-500"><%= label %></span>
                <span class="text-stone-400 font-normal"><%= facilities.size %></span>
              </h3>
              <ul class="space-y-0.5">
                <% by_name.first(4).each do |name, branches| %>
                  <li class="text-sm leading-snug">
                    <%= link_to name, facility_path(branches.first),
                                class: "text-stone-700 hover:text-blue-600" %><% if branches.size > 1 %><span class="text-stone-400 text-xs ml-1">&times;<%= branches.size %></span><% end %>
                  </li>
                <% end %>
              </ul>
              <% remaining = by_name.drop(4) %>
              <% if remaining.any? || unnamed.any? %>
                <details class="mt-0.5">
                  <summary class="text-xs text-stone-400 cursor-pointer hover:text-blue-600">+ <%= remaining.size + unnamed.size %> more</summary>
                  <ul class="space-y-0.5 mt-0.5" style="max-height: 10rem; overflow-y: auto;">
                    <% remaining.each do |name, branches| %>
                      <li class="text-sm leading-snug">
                        <%= link_to name, facility_path(branches.first),
                                    class: "text-stone-700 hover:text-blue-600" %><% if branches.size > 1 %><span class="text-stone-400 text-xs ml-1">&times;<%= branches.size %></span><% end %>
                      </li>
                    <% end %>
                    <% unnamed.each do |facility| %>
                      <li class="text-sm leading-snug">
                        <%= link_to "Unnamed #{type.humanize.downcase}", facility_path(facility),
                                    class: "text-stone-400 hover:text-blue-600 italic" %>
                      </li>
                    <% end %>
                  </ul>
                </details>
              <% end %>
            </div>
          <% end %>
        </div>
        <p class="text-xs text-stone-400 mt-4">
          Facility data from BMC and OpenStreetMap.
        </p>
      </div>
    <% end %>

    <%# Discussions — only for mapped+ prabhags %>
    <div class="mb-8">
      <div class="flex items-center justify-between pb-2 border-b border-stone-200 mb-3">
        <h2 class="text-lg font-semibold text-stone-900">Discussions</h2>
        <% if user_signed_in? %>
          <%= link_to "Start a discussion", new_prabhag_discussion_path(@prabhag),
                      class: "text-sm text-blue-600 hover:text-blue-800 font-medium" %>
        <% else %>
          <%= link_to "Sign in to discuss", new_user_session_path,
                      class: "text-sm text-stone-400 hover:text-blue-600" %>
        <% end %>
      </div>
      <% recent_discussions = @prabhag.discussions.order(last_post_at: :desc, created_at: :desc).limit(5) %>
      <% if recent_discussions.any? %>
        <div class="space-y-3">
          <% recent_discussions.each do |discussion| %>
            <div class="flex items-start justify-between">
              <%= link_to discussion.title, prabhag_discussion_path(@prabhag, discussion),
                          class: "text-sm text-stone-800 hover:text-blue-700 font-medium" %>
              <span class="text-xs text-stone-400 whitespace-nowrap ml-4"><%= time_ago_in_words(discussion.last_post_at || discussion.created_at) %> ago</span>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-stone-400 italic">No discussions yet. Be the first to start one about your neighborhood.</p>
      <% end %>
    </div>

    <%# Mapping actions %>
    <% if user_signed_in? %>
      <% if @prabhag.assigned_to == current_user && @prabhag.status == 'assigned' %>
        <div class="mb-6">
          <%= link_to trace_prabhag_path(@prabhag),
                      class: "inline-flex items-center px-4 py-2 bg-green-600 hover:bg-green-700 text-white text-sm font-medium rounded" do %>
            <i class="fas fa-map-marked-alt mr-2"></i> Continue Mapping
          <% end %>
        </div>
      <% end %>
    <% end %>

    <%# PDF reference — collapsed %>
    <details class="mb-8">
      <summary class="text-sm font-semibold text-stone-600 cursor-pointer hover:text-stone-800">
        <i class="fas fa-file-pdf mr-1 text-red-400"></i> Official MCGM Reference Map
      </summary>
      <div class="mt-3">
        <%= render partial: "prabhags/pdf_embed", locals: { prabhag: @prabhag } %>
      </div>
    </details>

  <% end %>

  <%# Boundary History — collapsed, shown if any boundaries exist %>
  <% if @prabhag.boundaries.any? %>
    <details class="mb-8">
      <summary class="text-sm font-semibold text-stone-600 cursor-pointer hover:text-stone-800">
        Boundary History (<%= @prabhag.boundaries.count %>)
      </summary>
      <div class="space-y-3 mt-3">
        <% @prabhag.boundaries.order(created_at: :desc).each do |b| %>
          <div class="pb-3 border-b border-stone-100 last:border-b-0 text-sm">
            <span class="font-medium <%= { 'approved' => 'text-green-700', 'rejected' => 'text-red-700', 'canonical' => 'text-purple-700', 'pending' => 'text-yellow-700' }[b.status] || 'text-stone-600' %>">
              <%= b.status.humanize %>
            </span>
            <span class="text-stone-400">· <%= b.source_type.humanize %> · <%= b.year %></span>
            <span class="text-stone-400">· <%= time_ago_in_words(b.created_at) %> ago</span>
            <% if b.submitted_by %>
              <span class="text-stone-500">by <%= b.submitted_by.name || b.submitted_by.email.split('@').first %></span>
            <% end %>
            <% if b.rejection_reason.present? %>
              <div class="text-red-600 mt-0.5"><%= b.rejection_reason %></div>
            <% end %>
          </div>
        <% end %>
      </div>
    </details>
  <% end %>
</div>
