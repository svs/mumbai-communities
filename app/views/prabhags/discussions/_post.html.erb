<div id="post-<%= post.id %>" class="<%= 'ml-6' if depth > 0 %> border-l-2 border-gray-100 pl-4 py-3" data-controller="thread">
  <div class="flex justify-between items-start">
    <div class="text-sm text-gray-500">
      <span class="font-medium text-gray-700"><%= post.user.name || post.user.email %></span> &middot;
      <%= time_ago_in_words(post.created_at) %> ago
    </div>
    <div class="flex gap-2 text-xs">
      <% if user_signed_in? && discussion.open? && depth < 4 %>
        <button data-action="thread#toggleReply" class="text-gray-500 hover:text-blue-600">Reply</button>
      <% end %>
      <% if user_signed_in? && (post.user == current_user || current_user.admin?) %>
        <%= link_to "Edit", edit_prabhag_discussion_post_path(prabhag, discussion, post), class: "text-gray-500 hover:text-blue-600" %>
        <%= link_to "Delete", prabhag_discussion_post_path(prabhag, discussion, post), data: { turbo_method: :delete, turbo_confirm: "Delete this reply?" }, class: "text-gray-500 hover:text-red-600" %>
      <% end %>
    </div>
  </div>

  <div class="text-sm text-gray-800 mt-1">
    <%= simple_format(post.body) %>
  </div>

  <!-- Inline Reply Form (hidden by default) -->
  <% if user_signed_in? && discussion.open? && depth < 4 %>
    <div data-thread-target="replyForm" class="hidden mt-3">
      <%= form_with(model: Post.new, url: prabhag_discussion_posts_path(prabhag, discussion), class: "space-y-2") do |f| %>
        <%= f.hidden_field :parent_id, value: post.id %>
        <%= f.text_area :body, rows: 3, placeholder: "Write a reply...", class: "w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-blue-500" %>
        <div class="flex gap-2 justify-end">
          <button type="button" data-action="thread#toggleReply" class="text-sm text-gray-500 hover:text-gray-700">Cancel</button>
          <%= f.submit "Reply", class: "bg-blue-600 text-white px-3 py-1 rounded text-sm hover:bg-blue-700 cursor-pointer" %>
        </div>
      <% end %>
    </div>
  <% end %>

  <!-- Nested Replies -->
  <% if post.replies.any? %>
    <div class="mt-2">
      <% post.replies.order(:created_at).each do |reply| %>
        <%= render partial: "prabhags/discussions/post", locals: { post: reply, prabhag: prabhag, discussion: discussion, depth: depth + 1 } %>
      <% end %>
    </div>
  <% end %>
</div>
