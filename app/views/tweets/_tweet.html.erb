<% if ENV["TWEET_EMBED"] == "true" %>
  <blockquote class="twitter-tweet" data-dnt="true">
    <p><%= tweet.body %></p>
    &mdash; <%= tweet.author_name %> (@<%= tweet.author_username %>)
    <a href="https://x.com/<%= tweet.author_username || "i" %>/status/<%= tweet.tweet_id %>"><%= tweet.tweeted_at&.strftime("%B %d, %Y") %></a>
  </blockquote>
<% else %>
  <%= link_to ward_tweet_path(tweet.ward, tweet),
     data: { turbo_frame: "_top" },
     class: "block border border-stone-200 rounded-lg p-4 hover:border-stone-300 hover:bg-stone-50/50 transition-colors" do %>

    <% media_count = tweet.media_urls&.size || 0 %>
    <% side_media = media_count.between?(1, 2) %>

    <div class="<%= 'flex gap-3' if side_media %>">
      <div class="<%= 'flex-1 min-w-0' if side_media %>">
        <%# Author line %>
        <div class="flex items-center gap-2 mb-2">
          <div class="w-8 h-8 rounded-full bg-stone-200 flex items-center justify-center text-xs font-bold text-stone-500 shrink-0">
            <%= tweet.author_username&.slice(0, 2)&.upcase || "?" %>
          </div>
          <div class="min-w-0">
            <div class="text-sm font-semibold text-stone-900 truncate"><%= tweet.author_name || tweet.author_username %></div>
            <div class="text-xs text-stone-400">@<%= tweet.author_username %></div>
          </div>
        </div>

        <%# Body with formatted @mentions and #hashtags %>
        <p class="text-base text-stone-700 leading-relaxed mb-3 whitespace-pre-line"><%= format_tweet_body(tweet.body) %></p>
      </div>

      <%# 1-2 images — right of text, stacked %>
      <% if side_media %>
        <div class="flex flex-col gap-1 shrink-0">
          <% tweet.media_urls.first(2).each do |media| %>
            <% url = media["url"] || media["preview_image_url"] %>
            <% next unless url %>
            <div class="relative inline-block">
              <img src="<%= url %>" alt="" class="w-28 h-28 object-cover rounded-lg" loading="lazy">
              <% if media["type"] == "video" || media["type"] == "animated_gif" %>
                <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2">
                  <div class="bg-black/60 rounded-full w-10 h-10 flex items-center justify-center">
                    <svg class="w-5 h-5 text-white ml-0.5" fill="currentColor" viewBox="0 0 20 20"><path d="M6.3 2.8A1.5 1.5 0 004 4.11v11.78a1.5 1.5 0 002.3 1.31l9.34-5.89a1.5 1.5 0 000-2.62L6.3 2.8z"/></svg>
                  </div>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

    <%# 3-4 images — below text %>
    <% if media_count >= 3 %>
      <div class="flex gap-1 mb-3 rounded-lg overflow-hidden">
        <% tweet.media_urls.first(4).each do |media| %>
          <% url = media["url"] || media["preview_image_url"] %>
          <% next unless url %>
          <div class="relative inline-block">
            <img src="<%= url %>" alt="" class="max-h-36 object-contain" loading="lazy">
            <% if media["type"] == "video" || media["type"] == "animated_gif" %>
              <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2">
                <div class="bg-black/60 rounded-full w-10 h-10 flex items-center justify-center">
                  <svg class="w-5 h-5 text-white ml-0.5" fill="currentColor" viewBox="0 0 20 20"><path d="M6.3 2.8A1.5 1.5 0 004 4.11v11.78a1.5 1.5 0 002.3 1.31l9.34-5.89a1.5 1.5 0 000-2.62L6.3 2.8z"/></svg>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# Footer %>
    <div class="flex items-center justify-between text-xs text-stone-400">
      <span><%= tweet.tweeted_at&.strftime("%-d %b %Y, %-I:%M %p") %></span>
      <div class="flex items-center gap-3">
        <% if tweet.reply_count.to_i > 0 %>
          <span><i class="far fa-comment"></i> <%= tweet.reply_count %></span>
        <% end %>
        <% if tweet.retweet_count.to_i > 0 %>
          <span><i class="fas fa-retweet"></i> <%= tweet.retweet_count %></span>
        <% end %>
        <% if tweet.like_count.to_i > 0 %>
          <span><i class="far fa-heart"></i> <%= tweet.like_count %></span>
        <% end %>
      </div>
    </div>
  <% end %>
<% end %>
