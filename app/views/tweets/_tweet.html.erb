<% if ENV["TWEET_EMBED"] == "true" %>
  <blockquote class="twitter-tweet" data-dnt="true">
    <p><%= tweet.body %></p>
    &mdash; <%= tweet.author_name %> (@<%= tweet.author_username %>)
    <a href="https://twitter.com/<%= tweet.author_username %>/status/<%= tweet.tweet_id %>"><%= tweet.tweeted_at&.strftime("%B %d, %Y") %></a>
  </blockquote>
<% else %>
  <a href="https://twitter.com/<%= tweet.author_username %>/status/<%= tweet.tweet_id %>"
     target="_blank" rel="noopener"
     class="block border border-stone-200 rounded-lg p-4 hover:border-stone-300 hover:bg-stone-50/50 transition-colors">

    <%# Author line %>
    <div class="flex items-center gap-2 mb-2">
      <div class="w-8 h-8 rounded-full bg-stone-200 flex items-center justify-center text-xs font-bold text-stone-500 shrink-0">
        <%= tweet.author_username[0..1].upcase %>
      </div>
      <div class="min-w-0">
        <div class="text-sm font-semibold text-stone-900 truncate"><%= tweet.author_name || tweet.author_username %></div>
        <div class="text-xs text-stone-400">@<%= tweet.author_username %></div>
      </div>
    </div>

    <%# Body %>
    <p class="text-sm text-stone-800 leading-relaxed mb-3"><%= tweet.body.gsub(%r{https?://t\.co/\w+}, '').strip %></p>

    <%# Media %>
    <% if tweet.media_urls.present? %>
      <div class="flex gap-1 mb-3 rounded-lg overflow-hidden">
        <% tweet.media_urls.each do |media| %>
          <% url = media["url"] || media["preview_image_url"] %>
          <% next unless url %>
          <div class="relative flex-1">
            <img src="<%= url %>" alt="" class="w-full h-48 object-cover" loading="lazy">
            <% if media["type"] == "video" || media["type"] == "animated_gif" %>
              <div class="absolute inset-0 flex items-center justify-center bg-black/20">
                <div class="bg-black/60 rounded-full w-10 h-10 flex items-center justify-center">
                  <svg class="w-5 h-5 text-white ml-0.5" fill="currentColor" viewBox="0 0 20 20"><path d="M6.3 2.8A1.5 1.5 0 004 4.11v11.78a1.5 1.5 0 002.3 1.31l9.34-5.89a1.5 1.5 0 000-2.62L6.3 2.8z"/></svg>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# Footer %>
    <div class="flex items-center justify-between text-xs text-stone-400">
      <span><%= tweet.tweeted_at&.strftime("%-d %b %Y, %-I:%M %p") %></span>
      <div class="flex items-center gap-3">
        <% if tweet.like_count.to_i > 0 %>
          <span>&#9829; <%= tweet.like_count %></span>
        <% end %>
        <% if tweet.retweet_count.to_i > 0 %>
          <span>&#8635; <%= tweet.retweet_count %></span>
        <% end %>
      </div>
    </div>
  </a>
<% end %>
